/* 全局样式重置 */
page {
  --primary: #07c160;
  --primary-dark: #06ad56;
  --warning: #ffbe00;
  --danger: #fa5151;
  --text: #333333;
  --text-secondary: #666666;
  --text-muted: #999999;
  --bg: #f5f5f5;
  --border: #e5e5e5;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  background-color: var(--bg);
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 40rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-primary {
  background: var(--primary);
  color: #ffffff;
}

.btn-primary[disabled] {
  background: #c9f2d7;
  color: #ffffff;
}

.btn-secondary {
  background: #f0f0f0;
  color: var(--text);
}

.btn-outline {
  background: transparent;
  border: 2rpx solid var(--border);
  color: var(--text);
}

/* 卡片样式 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 输入框样式 */
.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input:focus {
  background: #f0f0f0;
}

/* 通用间距 */
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mt-40 { margin-top: 40rpx; }
.mb-20 { margin-bottom: 20rpx; }
.p-30 { padding: 30rpx; }

/* 加载动画 */
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading {
  animation: spin 1s linear infinite;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: var(--text-muted);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
}