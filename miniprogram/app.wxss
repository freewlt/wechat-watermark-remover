/**app.wxss**/
page {
  font-family: -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, sans-serif;
  background-color: #f5f7fa;
}

.container {
  padding: 30rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #f0f2f5;
  color: #333;
  border-radius: 50rpx;
  font-size: 28rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.tips {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 30rpx;
}
