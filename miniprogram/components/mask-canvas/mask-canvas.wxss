/* components/mask-canvas/mask-canvas.wxss */
.mask-canvas-wrapper {
  position: relative;
  width: 100%;
  height: 100%;
}

.mask-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.brush-cursor {
  position: absolute;
  border: 2rpx solid rgba(255, 0, 0, 0.8);
  border-radius: 50%;
  pointer-events: none;
  transform: translate(-50%, -50%);
  box-shadow: 0 0 10rpx rgba(255, 0, 0, 0.3);
}