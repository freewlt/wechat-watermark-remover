<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card" bindtap="onUserCardTap">
    <!-- 已登录状态 -->
    <block wx:if="{{isLoggedIn}}">
      <view class="user-avatar">
        <image src="{{userInfo.avatarUrl}}" mode="aspectFill"/>
      </view>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickName}}</text>
        <view class="user-badge" wx:if="{{isVip}}">
          <text class="vip-icon">👑</text>
          <text>VIP会员</text>
        </view>
        <view class="user-badge free" wx:else>
          <text>免费用户</text>
        </view>
      </view>
    </block>
    <!-- 未登录状态 -->
    <block wx:else>
      <view class="user-avatar login-avatar">
        <text class="avatar-placeholder">👤</text>
      </view>
      <view class="user-info">
        <text class="user-name login-text">点击登录</text>
        <view class="user-badge free">
          <text>登录后享受更多功能</text>
        </view>
      </view>
    </block>
  </view>

