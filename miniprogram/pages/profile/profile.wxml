  <!-- 功能列表 -->
  <view class="menu-list">
    <view class="menu-group">
      <view class="menu-item" bindtap="watchAd">
        <text class="menu-icon">📺</text>
        <text class="menu-text">看视频得次数</text>
        <text class="menu-extra">+3次</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="inviteFriend">
        <text class="menu-icon">🎁</text>
        <text class="menu-text">邀请好友</text>
        <text class="menu-extra">双方+5次</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="showHistory">
        <text class="menu-icon">📋</text>
        <text class="menu-text">处理记录</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="clearCache">
        <text class="menu-icon">🗑️</text>
        <text class="menu-text">清理缓存</text>
        <text class="menu-extra">{{cacheSize}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="showAbout">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="showAgreement">
        <text class="menu-icon">📄</text>
        <text class="menu-text">用户协议</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="showPrivacy">
        <text class="menu-icon">🔒</text>
        <text class="menu-text">隐私政策</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <button class="menu-item contact" open-type="contact">
        <text class="menu-icon">💬</text>
        <text class="menu-text">联系客服</text>
        <text class="menu-arrow">›</text>
      </button>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>版本 {{version}}</text>
  </view>
</view>
