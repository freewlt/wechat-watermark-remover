/* pages/profile/profile.wxss */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255,255,255,0.3);
  margin-right: 30rpx;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-avatar.open-data {
  width: 100%;
  height: 100%;
}

/* 登录状态头像 */
.login-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.2);
}

.avatar-placeholder {
  font-size: 60rpx;
}

/* 登录文字 */
.login-text {
  color: #fff;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.user-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: rgba(255,215,0,0.9);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #333;
}

.user-badge.free {
  background: rgba(255,255,255,0.3);
  color: #fff;
}

.vip-icon {
  font-size: 28rpx;
}

/* 统计卡片 */
.stats-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-around;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 2rpx;
  background: #eee;
}

/* VIP 横幅 */
.vip-banner {
  background: linear-gradient(90deg, #f5af19 0%, #f12711 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.vip-content {
  flex: 1;
}

.vip-title {
  display: block;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.vip-desc {
  display: block;
  color: rgba(255,255,255,0.9);
  font-size: 24rpx;
}

.vip-btn {
  padding: 16rpx 30rpx;
  background: #fff;
  color: #f12711;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: bold;
}

/* 菜单列表 */
.menu-list {
  margin-bottom: 40rpx;
}

.menu-group {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  background: #fff;
  width: 100%;
  box-sizing: border-box;
  text-align: left;
  margin: 0;
  line-height: inherit;
}

.menu-item::after {
  border: none;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 50rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-extra {
  font-size: 24rpx;
  color: #999;
  margin-right: 10rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 24rpx;
}