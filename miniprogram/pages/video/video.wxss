/* pages/video/video.wxss */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.input-section {
  position: relative;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.url-input {
  width: 100%;
  height: 160rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.paste-btn {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  padding: 12rpx 30rpx;
  background: #07c160;
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.parse-btn {
  margin-top: 30rpx;
  background: #07c160;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
}

.parse-btn.loading {
  opacity: 0.7;
}

.result {
  margin-top: 40rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.preview-video {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
}

.action-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn {
  flex: 1;
  font-size: 28rpx;
  border-radius: 40rpx;
}

.btn.primary {
  background: #07c160;
  color: #fff;
}

.btn.secondary {
  background: #f0f0f0;
  color: #333;
}

.history {
  margin-top: 50rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.history-item {
  display: flex;
  background: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.time {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}