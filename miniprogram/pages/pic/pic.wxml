<!--pages/pic/pic.wxml-->
<view class="container">
  <!-- 步骤指示器 -->
  <view class="step-bar">
    <view class="step {{step >= 1 ? 'active' : ''}}">
      <view class="step-num">1</view>
      <text>选择图片</text>
    </view>
    <view class="step-line {{step >= 2 ? 'active' : ''}}"></view>
    <view class="step {{step >= 2 ? 'active' : ''}}">
      <view class="step-num">2</view>
      <text>自动识别/涂抹水印</text>
    </view>
    <view class="step-line {{step >= 3 ? 'active' : ''}}"></view>
    <view class="step {{step >= 3 ? 'active' : ''}}">
      <view class="step-num">3</view>
      <text>处理完成</text>
    </view>
  </view>

  <!-- 步骤1: 选择图片 -->
  <view class="step-content" wx:if="{{step === 1}}">
    <view class="upload-area" bindtap="chooseImage">
      <view class="upload-placeholder">
        <text class="upload-icon">+</text>
        <text class="upload-text">点击选择图片</text>
        <text class="upload-tip">支持 JPG、PNG 格式</text>
      </view>
    </view>
    
    <view class="quick-actions">
      <button class="quick-btn" bindtap="chooseImage" data-source="camera">
        <text>📷 拍照</text>
      </button>
      <button class="quick-btn" bindtap="chooseImage" data-source="album">
        <text>🖼️ 从相册选</text>
      </button>
    </view>
  </view>

  <!-- 步骤2: 涂抹编辑 -->
  <scroll-view class="step-content scrollable" wx:if="{{step === 2}}" scroll-y="true">
    <view class="canvas-container" style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;">
      <!-- 原图显示 -->
      <image
        class="preview-image"
        src="{{originalImage}}"
        mode="aspectFit"
        style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;"
      />

      <!-- 涂抹层 -->
      <mask-canvas
        id="maskCanvas"
        width="{{canvasWidth}}"
        height="{{canvasHeight}}"
        brushSize="{{brushSize}}"
        brushColor="rgba(255, 0, 0, 0.5)"
        bind:ready="onMaskCanvasReady"
        bind:change="onMaskChange"
      />
    </view>

    <!-- 工具栏 -->
    <view class="toolbar">
      <view class="tips-bar">
        <text class="tips-text">💡 提示：直接点击"开始处理"自动识别水印，或涂抹水印区域后处理</text>
      </view>
      <view class="tool-group">
        <text class="tool-label">画笔大小</text>
        <slider 
          class="brush-slider"
          min="10" 
          max="80" 
          value="{{brushSize}}" 
          block-size="24"
          activeColor="#07c160"
          bindchange="onBrushSizeChange"
        />
        <text class="brush-value">{{brushSize}}px</text>
      </view>
      
      <view class="tool-actions">
        <button class="tool-btn" bindtap="undo" disabled="{{undoStack.length === 0}}">
          <text>↩️ 撤销</text>
        </button>
        <button class="tool-btn" bindtap="clearMask">
          <text>🗑️ 清空</text>
        </button>
        <button class="tool-btn" bindtap="toggleMask">
          <text>{{showMask ? '🙈' : '🙉'}} 预览</text>
        </button>
      </view>
    </view>

    <view class="action-bar">
      <button class="btn btn-secondary" bindtap="resetImage">重新选择</button>
      <button class="btn btn-primary" bindtap="processImage">
        {{processing ? '处理中...' : '开始处理'}}
      </button>
    </view>
  </scroll-view>

  <!-- 步骤3: 结果展示 -->
  <scroll-view class="step-content scrollable" wx:if="{{step === 3}}" scroll-y="true">
    <view class="result-container">
      <!-- 对比模式 -->
      <view class="compare-wrapper" wx:if="{{compareMode}}">
        <view class="compare-image original">
          <image src="{{originalImage}}" mode="widthFix"/>
          <text class="compare-label">原图</text>
        </view>
        <view class="compare-image result">
          <image src="{{resultImage}}" mode="widthFix"/>
          <text class="compare-label">处理后</text>
        </view>
      </view>

      <!-- 单图模式 -->
      <view class="single-result" wx:else>
        <image src="{{resultImage}}" mode="widthFix" bindtap="previewImage"/>
      </view>

      <view class="view-toggle" bindtap="toggleCompare">
        <text>{{compareMode ? '👁️ 单图查看' : '👀 对比查看'}}</text>
      </view>
    </view>

    <view class="result-actions">
      <button class="btn btn-secondary" bindtap="backToEdit">返回编辑</button>
      <button class="btn btn-primary" bindtap="saveImage">保存到相册</button>
      <button class="btn btn-outline" bindtap="processNew">处理新图片</button>
    </view>
  </scroll-view>

  <!-- 使用提示 -->
  <view class="help-card" wx:if="{{step === 1}}">
    <view class="help-title">💡 如何使用</view>
    <view class="help-step">
      <text class="num">1</text>
      <text>上传需要处理的图片</text>
    </view>
    <view class="help-step">
      <text class="num">2</text>
      <text>用自动识别或手指涂抹水印区域（红色标记）</text>
    </view>
    <view class="help-step">
      <text class="num">3</text>
      <text>点击处理，AI自动修复背景</text>
    </view>
  </view>
</view>